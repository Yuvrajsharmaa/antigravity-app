{
  "expo": {
    "name": "Antigravity",
    "slug": "antigravity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "antigravity",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F5F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antigravity.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Antigravity needs camera access for video sessions.",
        "NSMicrophoneUsageDescription": "Antigravity needs microphone access for video sessions."
      }
    },
    "android": {
      "package": "com.antigravity.app",
      "adaptiveIcon": {
        "backgroundColor": "#F6F5F2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera"
    ]
  }
}
